dat <- MASS::mvrnorm(20, c(0, 0))
dat <- MASS::mvrnorm(20, c(0, 0), diag(2))
dat <- MASS::mvrnorm(5, c(2, 2), 0.3*diag(2))
plot(dat)
dat <- rbind(MASS::mvrnorm(20, c(0, 0), diag(2)), MASS::mvrnorm(5, c(2, 2), 0.3*diag(2)))
plot(dat)
dat <- rbind(MASS::mvrnorm(20, c(0, 0), 0.5*diag(2)), MASS::mvrnorm(5, c(2, 2), 0.3*diag(2)))
plot(dat)
dat <- rbind(MASS::mvrnorm(20, c(0, 0), 0.5*diag(2)), MASS::mvrnorm(5, c(3, 3), 0.1*diag(2)))
plot(dat)
kmeans(dat, 2)
?mclust::Mclust
